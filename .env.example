# ohwow Environment Variables
# Copy to .env.local and fill in the values you need.
# All variables are optional. ohwow works out of the box with Ollama.

# ─── Core ──────────────────────────────────────────────
# OHWOW_LICENSE_KEY=          # License key for ohwow.fun cloud features
# OHWOW_PORT=7700             # HTTP server port
# OHWOW_DB_PATH=              # Custom SQLite database path (default: ~/.ohwow/ohwow.db)
# OHWOW_LOCAL_URL=            # Override local URL (for tunnels)
# OHWOW_CLOUD_URL=            # Override cloud URL (default: https://ohwow.fun)
# OHWOW_HEADLESS=             # Set to 1 for headless/daemon mode (no TUI)

# ─── AI Models ─────────────────────────────────────────
# ANTHROPIC_API_KEY=          # Anthropic API key for Claude models
# ANTHROPIC_OAUTH_TOKEN=      # Alternative: OAuth token for Anthropic
# OHWOW_MODEL_SOURCE=         # Force model source: "anthropic", "ollama", or "openrouter"
# OHWOW_CLOUD_MODEL=          # Claude model to use (default: claude-sonnet-4-20250514)
# OHWOW_PREFER_LOCAL=         # Set to "true" to prefer Ollama for all tasks

# ─── Ollama ────────────────────────────────────────────
# OHWOW_OLLAMA_URL=           # Ollama server URL (default: http://127.0.0.1:11434)
# OHWOW_OLLAMA_MODEL=         # Default Ollama model (default: qwen3:4b)
# OHWOW_ORCHESTRATOR_MODEL=   # Model for orchestrator (defaults to OHWOW_OLLAMA_MODEL)
# OHWOW_QUICK_MODEL=          # Lightweight model for fast tasks
# OHWOW_OCR_MODEL=            # Model for OCR tasks

# ─── OpenRouter ────────────────────────────────────────
# OPENROUTER_API_KEY=         # OpenRouter API key (alternative to Anthropic)
# OPENROUTER_MODEL=           # OpenRouter model ID

# ─── Browser Automation ────────────────────────────────
# OHWOW_BROWSER_HEADLESS=     # Set to "false" to show browser window

# ─── Scrapling (Web Scraping) ──────────────────────────
# OHWOW_SCRAPLING_PORT=       # Scrapling server port
# OHWOW_SCRAPLING_AUTO_START= # Auto-start scrapling server
# OHWOW_SCRAPLING_PROXY=      # Proxy URL for scraping

# ─── Networking ────────────────────────────────────────
# OHWOW_WORKSPACE_GROUP=      # Mesh group name (default: "default")
# OHWOW_DEVICE_ROLE=          # Device role: "hybrid", "worker", or "coordinator"
# OHWOW_TUNNEL_ENABLED=       # Enable Cloudflare tunnel

# ─── Enterprise ────────────────────────────────────────
# ENTERPRISE_JWT_SECRET=      # JWT secret for enterprise mode
