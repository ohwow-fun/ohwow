{
  "name": "ohwow",
  "version": "0.5.2",
  "description": "Local-first AI business operating system. Put your business ops on autopilot with AI agents that learn, remember, and coordinate.",
  "license": "MIT",
  "author": "Jesus David Oñoro Delgado <ogsus@ohwow.fun>",
  "type": "module",
  "main": "./dist/api.js",
  "types": "./dist/api.d.ts",
  "exports": {
    ".": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./mcp-server": {
      "import": "./dist/mcp-server/index.js",
      "types": "./dist/mcp-server/index.d.ts"
    }
  },
  "bin": {
    "ohwow": "bin/ohwow.js",
    "ohwow-mcp": "bin/ohwow-mcp.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ohwow-fun/ohwow.git"
  },
  "homepage": "https://ohwow.fun",
  "keywords": [
    "ai",
    "agents",
    "runtime",
    "cli",
    "ollama",
    "claude",
    "automation",
    "local-first",
    "business",
    "mcp",
    "orchestrator",
    "whatsapp",
    "telegram",
    "crm",
    "workflow"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run build:web && tsup && npm run copy-assets",
    "build:web": "cd src/web && npm install --ignore-scripts && npx vite build",
    "copy-assets": "node -e \"require('fs').cpSync('src/db/migrations','dist/migrations',{recursive:true})\"",
    "clean": "node -e \"['dist','tsconfig.build.tsbuildinfo'].forEach(p=>{try{require('fs').rmSync(p,{recursive:true,force:true})}catch{}})\"",
    "prepublishOnly": "npm run clean && npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:web": "cd src/web && npx vite --port 7701",
    "lint": "eslint src/ --ignore-pattern 'src/web/'",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-env": "tsx scripts/check-env.ts",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "src/**/*.ts": "eslint --fix",
    "*.ts": "bash -c 'npx tsc --noEmit'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "^1.9.0",
    "@whiskeysockets/baileys": "^6.7.16",
    "better-sqlite3": "^11.0.0",
    "bonjour-service": "^1.3.0",
    "busboy": "^1.6.0",
    "cloudflared": "^0.7.1",
    "cors": "^2.8.6",
    "cron-parser": "^5.5.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "ink": "^6.8.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "jose": "^6.1.3",
    "pdf-lib": "^1.17.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode-terminal": "^0.12.0",
    "quickchart-js": "^3.1.3",
    "react": "^19.2.0",
    "rss-parser": "^3.13.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@browserbasehq/stagehand": "^3.2.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "node-pty": "^1.1.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.0",
    "@types/busboy": "^1.5.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/qrcode-terminal": "^0.12.0",
    "@types/react": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "lint-staged": "^16.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "langsmith": ">=0.5.0",
    "file-type": ">=21.3.1"
  }
}
