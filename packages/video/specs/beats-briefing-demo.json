{
  "id": "beats-briefing-demo",
  "version": 1,
  "fps": 30,
  "width": 1920,
  "height": 1080,
  "brand": {
    "colors": { "bg": "#0a1020", "text": "#f4f7fb", "accent": "#e3b58a" },
    "fonts": {
      "sans": "Inter, system-ui, sans-serif",
      "mono": "JetBrains Mono, monospace",
      "display": "Merriweather, Georgia, serif"
    },
    "glass": {
      "background": "rgba(255,255,255,0.04)",
      "border": "1px solid rgba(255,255,255,0.08)",
      "borderRadius": 12,
      "backdropFilter": "blur(12px)"
    }
  },
  "palette": { "seedHue": 215, "harmony": "complementary", "mood": "electric" },
  "voiceovers": [],
  "transitions": [{ "kind": "fade", "durationInFrames": 24 }],
  "scenes": [
    {
      "id": "intro",
      "durationInFrames": 120,
      "narration": "Two moves in AI today, April seventeenth.",
      "motion_graphic_prompt": "A chrome 'THE BRIEFING' title floats on a frosted glass slate; warm particles drift behind it.",
      "motion_beats": [
        { "primitive": "r3f.particle-cloud", "params": { "count": 220, "spread": 9, "color": "#e3b58a", "size": 0.04, "swirlSpeed": 0.05, "seed": 7 } },
        { "primitive": "r3f.glass-panel", "params": { "text": "THE BRIEFING", "subtitle": "APR 17 · TWO MOVES", "width": 9, "height": 3.2 } }
      ],
      "params": {
        "background": "#0a1020",
        "environmentPreset": "sunset",
        "camera": { "position": [0, 0.4, 10], "fov": 40 },
        "motionProfile": "asmr"
      }
    },
    {
      "id": "story-1a",
      "durationInFrames": 150,
      "narration": "Anthropic ships Opus 4.7 with a thirteen percent SWE-bench lift.",
      "motion_graphic_prompt": "A chrome 13% count-up bar rises from zero.",
      "motion_beats": [
        { "primitive": "r3f.particle-cloud", "params": { "count": 160, "spread": 10, "color": "#9ec7ff", "size": 0.035, "swirlSpeed": 0.04, "seed": 3 } },
        { "primitive": "r3f.count-up-bar", "params": { "target": 13, "max": 100, "unit": "%", "label": "SWE-bench lift", "color": "#f4eadb", "durationFrames": 90 } }
      ],
      "params": {
        "background": "#0a1020",
        "environmentPreset": "sunset",
        "camera": { "position": [0, 1.2, 7.5], "fov": 45 },
        "motionProfile": "asmr"
      }
    },
    {
      "id": "story-1b",
      "durationInFrames": 150,
      "narration": "Long horizon agentic coding, multi hour tasks, no drift.",
      "motion_graphic_prompt": "Three specs orbit a central axis in chrome pills.",
      "motion_beats": [
        { "primitive": "r3f.orbiting-tags", "params": { "tags": ["LONG-HORIZON", "AGENTIC", "CODING"], "radius": 2.8, "tagSize": 0.42, "color": "#e3b58a" } }
      ],
      "params": {
        "background": "#0a1020",
        "environmentPreset": "sunset",
        "camera": { "position": [0, 0.2, 8], "fov": 42 },
        "motionProfile": "asmr"
      }
    },
    {
      "id": "outro",
      "durationInFrames": 120,
      "narration": "Watch Mistral answer before Friday.",
      "motion_graphic_prompt": "A 'TOMORROW' glass slate breathes softly.",
      "motion_beats": [
        { "primitive": "r3f.particle-cloud", "params": { "count": 180, "spread": 10, "color": "#f0c89b", "size": 0.04, "swirlSpeed": 0.04, "seed": 11 } },
        { "primitive": "r3f.glass-panel", "params": { "text": "TOMORROW", "subtitle": "APR 18 · Watch Mistral's response", "width": 9.5, "height": 3.2 } }
      ],
      "params": {
        "background": "#0a1020",
        "environmentPreset": "sunset",
        "camera": { "position": [0, 0.4, 10], "fov": 40 },
        "motionProfile": "asmr"
      }
    }
  ]
}
