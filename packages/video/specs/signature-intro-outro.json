            "opacity": 0.36,
            "drift": 0.45,
            "driftSpeed": 0.05
          } },
          { "primitive": "r3f.floating-title", "params": {
            "text": "TOMORROW",
            "subtitle": "APR 18 · Watch Mistral's response",
            "titleSize": 1.3,
            "subtitleSize": 0.4,
            "position": [0, 0.2, 0],
            "subtitleOffsetY": -1.05,
            "kineticDelayFrames": 6,
            "kineticStaggerFrames": 4,
            "subtitleDelayFrames": 50,
            "subtitleFadeFrames": 24
          } },
          { "primitive": "r3f.logo-mark", "params": { "position": [4.6, 2.5, 0], "size": 0.6, "opacity": 0.88 } }
        ]
      }
    }
  ]
}
