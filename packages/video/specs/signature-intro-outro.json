{
  "id": "signature-intro-outro",
  "version": 1,
  "fps": 30,
  "width": 1920,
  "height": 1080,
  "brand": {
    "colors": { "bg": "#000000", "text": "#ffffff", "accent": "#e3b58a" },
    "fonts": {
      "sans": "Inter, system-ui, sans-serif",
      "mono": "JetBrains Mono, monospace",
      "display": "Merriweather, Georgia, serif"
    },
    "glass": {
      "background": "rgba(255,255,255,0.04)",
      "border": "1px solid rgba(255,255,255,0.08)",
      "borderRadius": 12,
      "backdropFilter": "blur(12px)"
    }
  },
  "palette": { "seedHue": 215, "harmony": "complementary", "mood": "electric" },
  "voiceovers": [],
  "transitions": [{ "kind": "fade", "durationInFrames": 8 }, { "kind": "fade", "durationInFrames": 10 }],
  "scenes": [
    {
      "id": "cold-open",
      "kind": "r3f-scene",
      "durationInFrames": 60,
      "params": {
        "background": "#000000",
        "environmentPreset": "night",
        "camera": { "position": [0, 0, 8], "fov": 40 },
        "motionProfile": "asmr",
        "primitives": [
          { "primitive": "r3f.logo-reveal", "params": { "size": 3.0, "particleCount": 160, "durationInFrames": 60 } }
        ]
      }
    },
    {
      "id": "intro",
      "kind": "r3f-scene",
      "durationInFrames": 180,
      "params": {
        "background": "#000000",
        "environmentPreset": null,
        "camera": { "position": [0, 0, 10], "fov": 38 },
        "motionProfile": "asmr",
        "primitives": [
          { "primitive": "r3f.color-fog", "params": {
            "orbs": [
              { "color": "#e3b58a", "x": -4.5, "y": 1.8, "z": -3, "radius": 4.5 },
              { "color": "#6b9fd4", "x": 4.2, "y": -1.4, "z": -2, "radius": 4.8 },
              { "color": "#b472c9", "x": -2.2, "y": -2.2, "z": -3.5, "radius": 3.8 },
              { "color": "#d86a8a", "x": 4.8, "y": 2.5, "z": -3, "radius": 3.5 },
              { "color": "#5fb8c6", "x": 0, "y": 0.5, "z": -5, "radius": 6.2 }
            ],
            "opacity": 0.38,
            "drift": 0.4,
            "driftSpeed": 0.06
          } },
          { "primitive": "r3f.floating-title", "params": {
            "text": "THE BRIEFING",
            "subtitle": "APR 17 · TWO MOVES",
            "titleSize": 1.2,
            "subtitleSize": 0.38,
            "position": [0, 0.2, 0],
            "subtitleOffsetY": -1.0,
            "kineticDelayFrames": 8,
            "kineticStaggerFrames": 4,
            "subtitleDelayFrames": 60,
            "subtitleFadeFrames": 24
          } },
          { "primitive": "r3f.logo-mark", "params": { "position": [4.6, 2.5, 0], "size": 0.6, "opacity": 0.88 } }
        ]
      }
    },
    {
      "id": "outro",
      "kind": "r3f-scene",
      "durationInFrames": 180,
      "params": {
        "background": "#000000",
        "environmentPreset": null,
        "camera": { "position": [0, 0, 10], "fov": 38 },
        "motionProfile": "asmr",
        "primitives": [
          { "primitive": "r3f.color-fog", "params": {
            "orbs": [
              { "color": "#9ec7ff", "x": -4.8, "y": 1.6, "z": -3, "radius": 5.0 },
              { "color": "#c98ee3", "x": 4.0, "y": -1.8, "z": -2.5, "radius": 4.2 },
              { "color": "#e3b58a", "x": -2.0, "y": -2.0, "z": -3.5, "radius": 3.8 },
              { "color": "#5fb8c6", "x": 4.5, "y": 2.2, "z": -3, "radius": 4.0 },
              { "color": "#b472c9", "x": 0, "y": 0.2, "z": -5, "radius": 6.0 }
