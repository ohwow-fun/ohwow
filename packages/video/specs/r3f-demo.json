  "scenes": [
    {
      "id": "demo-cube",
      "kind": "r3f-scene",
      "durationInFrames": 120,
      "narration": "Phase 0 verification: rotating chrome cube via R3F + Remotion bridge.",
      "params": {
        "background": "#0a1629",
        "fog": { "color": "#0a1629", "near": 5, "far": 20 },
        "camera": { "position": [0, 0, 7], "fov": 45 },
        "motionProfile": "asmr",
        "primitives": [
          {
            "primitive": "r3f.demo-cube",
            "params": { "color": "#f4eadb" }
          }
        ]
      }
    }
  ]
